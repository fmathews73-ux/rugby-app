  "scripts": {
    "start": "tsx src/server.ts",
    "test": "tsx --test test/smoke.test.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@rugby-app/pipeline": "*",
    "@rugby-app/shared": "*",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  }
}
