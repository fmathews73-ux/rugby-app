{
  "name": "@rugby-app/api",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Read-side HTTP API. Reads the synthetic dev dataset (or, at cutover, a real feed's persisted output) and serves canonical JSON to the mobile client.",
